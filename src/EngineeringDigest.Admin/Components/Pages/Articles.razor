@page "/articles"
@rendermode InteractiveServer
@inject EngineeringDigestDbContext Db
@inject IMessageBus Bus

<h1>Articles</h1>
@foreach (var article in articles)
{
    <article class="card">
        <h2>@article.Title</h2>
        <p><span class="badge">@article.Status</span> · @article.Video?.Title</p>
        <p>@article.Summary</p>
        <details>
            <summary>Preview markdown</summary>
            <pre>@article.ContentMarkdown</pre>
        </details>
        @if (article.Status == ArticleStatus.PendingReview)
        {
            <button @onclick="() => Approve(article.Id)">Approve</button>
        }
        @if (article.Status == ArticleStatus.Approved)
        {
            <button @onclick="() => Publish(article.Id)">Publish to Telegram</button>
        }
    </article>
}

@code {
    private List<EngineeringDigest.Domain.Entities.Article> articles = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task Approve(Guid articleId)
    {
        await Bus.PublishAsync(new EngineeringDigest.Application.Messaging.ApproveArticle(articleId));
        await LoadAsync();
    }

    private async Task Publish(Guid articleId)
    {
        await Bus.PublishAsync(new EngineeringDigest.Application.Messaging.PublishArticle(articleId));
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        articles = await Db.Articles.AsNoTracking()
            .Include(x => x.Video)
            .OrderByDescending(x => x.CreatedAt)
            .Take(100)
            .ToListAsync();
    }
}
